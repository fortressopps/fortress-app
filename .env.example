# ============================================================
# Fortress v7.24 — .env.example
# Copy to .env and fill in all required values
# ============================================================

# --- Database (REQUIRED) ------------------------------------
DATABASE_URL=postgresql://fortress_app:CHANGEME@localhost:5432/fortress?schema=public

# --- JWT (REQUIRED — min 32 chars) -------------------------
JWT_SECRET=CHANGEME_CHANGEME_CHANGEME_CHANGEME
REFRESH_TOKEN_SECRET=CHANGEME_CHANGEME_CHANGEME_CHANGEME

# --- App URLs (optional, defaults shown) -------------------
APP_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# --- Redis (optional) --------------------------------------
# REDIS_URL=redis://:CHANGEME@localhost:6379

# --- Email / SMTP (optional) --------------------------------
# If not set, email verification is silently skipped.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password

# --- Google OAuth (optional) --------------------------------
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Microsoft OAuth (optional) ----------------------------
# MICROSOFT_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
